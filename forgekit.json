{
  "schema": "https://forgekit.dev/schemas/forgecode-native.v1.json",
  "provider": "forgecode",
  "version": "2.6.0",
  "nativeRuntimeDir": ".",
  "globalRuntimeDir": "~/ForgeKit",
  "entrypoints": [
    ":ck:auto"
  ],
  "skillRegistry": "skills/registry.md",
  "instructions": [
    "AGENTS.md",
    "commands/ck:auto.md",
    "skills/auto/SKILL.md",
    "skills/orchestrator/SKILL.md",
    "skills/token-efficiency/SKILL.md",
    "skills/coding-level/SKILL.md",
    "communication/caveman.md"
  ],
  "assetDirectories": {
    "agents": "agents",
    "commands": "commands",
    "skills": "skills",
    "tests": "tests"
  },
  "routing": {
    "runtimeHint": true,
    "method": "mcp",
    "mcpServer": "mcp-server/index.cjs",
    "script": "scripts/route-intent.cjs",
    "evalScript": "scripts/eval-routing.cjs",
    "statusScript": "scripts/route-status.cjs",
    "fixtures": "tests/routing-fixtures.json",
    "confidenceThresholds": {
      "routeDirect": 0.90,
      "routeWithSecondary": 0.75,
      "uncertain": 0.60,
      "noMatch": 0.30
    },
    "gapThreshold": 0.15
  },
  "mcp": {
    "forgekit-router": {
      "command": "node",
      "args": ["mcp-server/index.cjs"],
      "tools": ["route_intent", "route_status", "route_log"]
    }
  },
  "integrations": {
    "rtk": "integrations/rtk.md",
    "gitnexus": "integrations/gitnexus.md",
    "contextMode": false,
    "cavemem": false
  },
  "hooks": {
    "privacy": {
      "enabled": true,
      "config": "hooks/privacy/privacy-block.cjs",
      "patterns": "hooks/privacy/patterns.json",
      "docs": "hooks/privacy/HOOK.md",
      "trigger": "before-output"
    },
    "notifications": {
      "enabled": false,
      "config": "hooks/notifications/notify.cjs",
      "webhookConfig": "hooks/config.json",
      "docs": "hooks/notifications/HOOK.md",
      "channels": [
        "telegram",
        "discord",
        "slack"
      ],
      "trigger": [
        "task-complete",
        "task-failed"
      ]
    },
    "sessionStart": {
      "enabled": true,
      "config": "hooks/session-start/session-init.cjs",
      "docs": "hooks/session-start/HOOK.md",
      "trigger": "session-start"
    },
    "preToolBudgetGuard": {
      "enabled": true,
      "config": "hooks/pre-tool/budget-guard.cjs",
      "docs": "hooks/pre-tool/HOOK.md",
      "trigger": "pre-tool-call"
    },
    "postToolRouteLog": {
      "enabled": true,
      "config": "hooks/post-tool/route-log.cjs",
      "docs": "hooks/post-tool/HOOK.md",
      "trigger": "post-routing-decision",
      "logDir": ".forgekit",
      "maxLogSize": 5242880
    }
  },
  "behavior": {
    "specFirst": true,
    "singleApprovalGate": true,
    "autonomousAfterApproval": true,
    "verifyBeforeFinalReport": true,
    "forgeCodeNativeFirst": true,
    "autoEnableCaveman": true,
    "maxPrimarySkillsInitial": 1
  }
}
