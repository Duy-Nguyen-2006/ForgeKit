{
  "schema": "https://forgekit.dev/schemas/forgecode-native.v1.json",
  "provider": "forgecode",
  "version": "2.0.0",
  "nativeRuntimeDir": ".",
  "globalRuntimeDir": "~/ForgeKit",
  "entrypoints": [
    ":ck:auto"
  ],
  "skillRegistry": "skills/registry.md",
  "instructions": [
    "AGENTS.md",
    "commands/ck:auto.md",
    "skills/auto/SKILL.md",
    "skills/orchestrator/SKILL.md",
    "skills/token-efficiency/SKILL.md",
    "communication/caveman.md"
  ],
  "assetDirectories": {
    "agents": "agents",
    "commands": "commands",
    "skills": "skills"
  },
  "integrations": {
    "rtk": "integrations/rtk.md",
    "serena": "integrations/serena.md",
    "contextMode": false,
    "cavemem": false
  },
  "hooks": {
    "privacy": {
      "enabled": true,
      "config": "hooks/privacy/patterns.json",
      "trigger": "before-output"
    },
    "notifications": {
      "enabled": false,
      "config": "hooks/config.json",
      "channels": [
        "telegram",
        "discord",
        "slack"
      ],
      "trigger": [
        "task-complete",
        "task-failed"
      ]
    },
    "sessionStart": {
      "enabled": true,
      "config": "hooks/session-start/context-load.md",
      "trigger": "session-start"
    }
  },
  "behavior": {
    "specFirst": true,
    "singleApprovalGate": true,
    "autonomousAfterApproval": true,
    "verifyBeforeFinalReport": true,
    "forgeCodeNativeFirst": true,
    "maxPrimarySkillsInitial": 1
  }
}
