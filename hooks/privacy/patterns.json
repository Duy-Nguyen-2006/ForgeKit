{
  "redact_patterns": [
    "(api[_-]?key|secret|token|password|bearer)\\s*[:=]\\s*['\"]?[A-Za-z0-9_\\-]{16,}['\"]?",
    "sk-[A-Za-z0-9]{20,}",
    "ghp_[A-Za-z0-9]{20,}",
    "xox[baprs]-[A-Za-z0-9-]{10,}",
    "(?:[0-9]{1,3}\\.){3}[0-9]{1,3}",
    "/Users/[^/\\s]+",
    "/home/[^/\\s]+"
